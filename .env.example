# DATABASE URL FOR PRISMA (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/CRM_DB?schema=public"

# AUTH SECRET FOR NEXT-AUTH
# Generate a secure secret using: openssl rand -base64 32
AUTH_SECRET="YOUR_NEXT_AUTH_SECRET_HERE"
NEXTAUTH_SECRET="YOUR_NEXT_AUTH_SECRET_HERE"

# NEXT-AUTH APP URL
# The canonical URL of your deployed application
# Example: https://pharmacy.yourdomain.com or http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# GOOGLE GEMINI / OPENAI API KEY FOR AI ASSISTANT
# Add your Gemini key (starts with AIzaSy) or OpenAI key (starts with sk-)
API_AI_KEY="YOUR_AI_PROVIDER_API_KEY_HERE"

# PORT NUMBER (Optional - Defaults to 3000)
PORT=3000
